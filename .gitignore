dist/
build/
out/
*.tgz
*.tar.gz

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Cache and Temporary Files
.cache/
*.tmp
*.temp
temp/
.cache/

# Test Coverage (if added later)
coverage/
*.lcov
.nyc_output/

