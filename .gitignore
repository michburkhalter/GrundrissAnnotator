!example.pdf

# Project Files (user data - should not be in version control)
*.json
!package.json
!package-lock.json
!tsconfig.json
!*.config.js

# Exported Files (user data)
*_annotiert.pdf
*_export.pdf
grundrisse_zusammengesetzt_annotiert.pdf

# Project Files (user data)
*_projekt.json
project_backup_*.json

# Browser-specific Files
*.crx
*.xpi

# Security Files
*.pem
*.key
*.crt
*.p12
*.pfx

# Documentation Build (if added later)
docs/_build/
site/

# Analytics and Monitoring
analytics/
monitoring/

# Local Development
.local/
localhost/
127.0.0.1/

# MacOS
.AppleDouble
.LSOverride

